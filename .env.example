# =========================
# APP CONFIG
# =========================

# Port ที่ server จะรัน (ตั้งเองได้ เช่น 3000, 5000, 5678)
PORT=5678

# โหมดการทำงาน: development | production
NODE_ENV=development

# อนุญาตให้ seed demo users แม้ NODE_ENV=production (ตั้งเป็น true เฉพาะเมื่อแน่ใจ)
ALLOW_DEMO_SEED=false

# URL ของ frontend (เช่น Vite dev server)
CLIENT_ORIGIN=http://localhost:5173


# =========================
# DATABASE (Turso / LibSQL)
# =========================

# Database URL ได้จาก Turso dashboard
# ไปที่: https://turso.tech → เลือก database → Copy "Database URL"
TURSO_DATABASE_URL=your-database-url-here

# Auth Token ได้จาก Turso CLI หรือ dashboard
# วิธี generate (CLI):
#   turso db tokens create <db-name>
TURSO_AUTH_TOKEN=your-turso-auth-token-here


# =========================
# AUTH (JWT)
# =========================

# Secret สำหรับ sign JWT (ต้องสุ่มเอง ห้ามใช้ค่าตัวอย่าง)
# วิธี generate (Node.js):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-key-here
